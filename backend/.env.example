# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/alumni_platform
# For MongoDB Atlas: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/alumni_platform
MONGODB_URI=mongodb+srv://arnoldeee123_db_user:arnold26@cluster0.uvz9uvd.mongodb.net/alumni_platform

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Admin Bootstrap (required if you want auto-create/promotion of admin account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password
ADMIN_NAME=Platform Administrator
ADMIN_DEPARTMENT=Administration
ADMIN_GRADUATION_YEAR=2015

# Email Configuration (Optional - for future email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# Client URL
CLIENT_URL=http://localhost:3000

# AI Assistant Configuration (optional)
# If omitted, the app falls back to a built-in non-AI draft template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=1536x1024
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_BACKGROUND=auto
OPENAI_IMAGE_MODERATION=auto

# Event image provider mode: openai, local, or fallback
EVENT_IMAGE_PROVIDER=fallback

# Local Stable Diffusion (Automatic1111) settings used when EVENT_IMAGE_PROVIDER=local
LOCAL_SD_API_URL=http://127.0.0.1:7860/sdapi/v1/txt2img
LOCAL_SD_TIMEOUT_MS=90000
LOCAL_SD_STEPS=3
LOCAL_SD_CFG_SCALE=5
LOCAL_SD_WIDTH=256
LOCAL_SD_HEIGHT=128
LOCAL_SD_SAMPLER=Euler a
# Optional model checkpoint name from your local SD WebUI, e.g. juggernautXL_v9.safetensors
LOCAL_SD_MODEL=

# Optional local classifier endpoint (Python microservice)
# Example: http://localhost:8001/classify
LOCAL_CLASSIFIER_URL=
LOCAL_CLASSIFIER_TIMEOUT_MS=2000
