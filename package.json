{
  "name": "alumni-platform",
  "version": "1.0.0",
  "description": "Digital Alumni Relationship Management Platform",
  "private": true,
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./setup.ps1",
