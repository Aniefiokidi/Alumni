{
  "version": 2,
  "buildCommand": "npm run install-all && npm run build:frontend",
  "public": true,
  "installCommand": "npm install && cd backend && npm install && cd ../frontend && npm install",
  "env": [
    "MONGODB_URI",
    "JWT_SECRET",
    "MAIL_USER",
    "MAIL_PASS",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "S3_BUCKET_NAME",
    "NODE_ENV",
    "GROQ_API_KEY",
    "GROQ_MODEL",
    "REACT_APP_API_BASE_URL"
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
